---
import Button from "./ui/Button.astro";
import { site } from "../config/site";

const links = [
  { href: "/#servizi", label: "Servizi" },
  { href: "/#esempi", label: "Esempi" },
  { href: "/#prezzi", label: "Prezzi" },
  { href: "/#faq", label: "FAQ" },
];
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-300"
  data-header
>
  <div class="mx-auto max-w-6xl px-5">
    <div
      class="mt-3 flex items-center justify-between rounded-full border border-white/10 bg-ink-950/80 px-4 py-2.5 backdrop-blur-md transition-all"
      data-header-bar
    >
      <a href="/#top" class="flex items-center gap-2 font-display text-lg font-extrabold text-white">
        <span class="grid h-8 w-8 place-items-center rounded-lg bg-brand-500 text-ink-950">B</span>
        {site.name}
      </a>

      <nav class="hidden items-center gap-7 md:flex" aria-label="Principale">
        {
          links.map((l) => (
            <a
              href={l.href}
              class="text-sm font-medium text-ink-200 transition-colors hover:text-white"
            >
              {l.label}
            </a>
          ))
        }
      </nav>

      <div class="hidden md:block">
        <Button href="/#contatti" size="md">Richiedi preventivo</Button>
      </div>

      <button
        type="button"
        class="grid h-10 w-10 place-items-center rounded-lg text-white md:hidden"
        aria-label="Apri menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-menu-toggle
      >
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false">
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </button>
    </div>

    <!-- Menu mobile -->
    <nav
      id="mobile-menu"
      class="mt-2 hidden rounded-2xl border border-white/10 bg-ink-950/95 p-4 backdrop-blur-md md:hidden"
      aria-label="Menu mobile"
      data-mobile-menu
    >
      {
        links.map((l) => (
          <a
            href={l.href}
            class="block rounded-lg px-3 py-2.5 text-base font-medium text-ink-100 hover:bg-white/5"
            data-mobile-link
          >
            {l.label}
          </a>
        ))
      }
      <a
        href="/#contatti"
        class="mt-2 block rounded-full bg-brand-500 px-3 py-2.5 text-center font-semibold text-ink-950"
        data-mobile-link
      >
        Richiedi preventivo
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");
  const header = document.querySelector<HTMLElement>("[data-header-bar]");

  function setMenu(open: boolean) {
    if (!menu || !toggle) return;
    menu.classList.toggle("hidden", !open);
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Chiudi menu" : "Apri menu");
  }

  toggle?.addEventListener("click", () => {
    setMenu(menu?.classList.contains("hidden") ?? false);
  });

  document
    .querySelectorAll("[data-mobile-link]")
    .forEach((l) => l.addEventListener("click", () => setMenu(false)));

  // Header più compatto/ombreggiato dopo lo scroll.
  const onScroll = () => {
    if (!header) return;
    header.classList.toggle("shadow-2xl", window.scrollY > 12);
    header.classList.toggle("ring-1", window.scrollY > 12);
    header.classList.toggle("ring-white/10", window.scrollY > 12);
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
</script>
