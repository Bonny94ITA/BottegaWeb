---
import Section from "./ui/Section.astro";
import Icon from "./ui/Icon.astro";
import Button from "./ui/Button.astro";
import { site, whatsappUrl } from "../config/site";

const keyConfigured = !site.web3formsKey.startsWith("REPLACE-");
---

<Section
  id="contatti"
  tone="dark"
  eyebrow="Parliamone"
  title="Raccontaci la tua attività"
  subtitle="Scrivici: ti rispondiamo con idee e un preventivo senza impegno."
>
  <div class="grid gap-10 lg:grid-cols-5">
    <!-- Contatti diretti -->
    <div class="reveal lg:col-span-2">
      <p class="text-ink-300">
        Preferisci un contatto diretto? Siamo a un messaggio di distanza.
      </p>
      <div class="mt-6 space-y-3">
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 rounded-xl border border-white/10 bg-white/5 p-4 transition-colors hover:bg-white/10"
        >
          <span class="grid h-10 w-10 place-items-center rounded-full bg-emerald-500 text-white">
            <Icon name="whatsapp" class="h-5 w-5" />
          </span>
          <span>
            <span class="block text-sm text-ink-400">WhatsApp</span>
            <span class="font-semibold text-white">Scrivici subito</span>
          </span>
        </a>
        <a
          href={`mailto:${site.email}`}
          class="flex items-center gap-3 rounded-xl border border-white/10 bg-white/5 p-4 transition-colors hover:bg-white/10"
        >
          <span class="grid h-10 w-10 place-items-center rounded-full bg-brand-500 text-ink-950">
            <Icon name="mail" class="h-5 w-5" />
          </span>
          <span>
            <span class="block text-sm text-ink-400">Email</span>
            <span class="font-semibold text-white">{site.email}</span>
          </span>
        </a>
      </div>
    </div>

    <!-- Form -->
    <div class="reveal lg:col-span-3">
      <form
        id="contact-form"
        action="https://api.web3forms.com/submit"
        method="POST"
        class="rounded-2xl border border-white/10 bg-white p-6 text-ink-800 sm:p-8"
        data-key-configured={String(keyConfigured)}
      >
        <input type="hidden" name="access_key" value={site.web3formsKey} />
        <input type="hidden" name="subject" value={`Nuova richiesta dal sito ${site.name}`} />
        <input type="hidden" name="from_name" value={site.name} />
        <!-- Honeypot anti-spam -->
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="mb-1.5 block text-sm font-medium text-ink-700">Nome *</span>
            <input
              type="text"
              name="name"
              required
              autocomplete="name"
              class="w-full rounded-xl border border-ink-200 px-4 py-2.5 outline-none transition focus:border-brand-400 focus:ring-2 focus:ring-brand-200"
              placeholder="Mario Rossi"
            />
          </label>
          <label class="block">
            <span class="mb-1.5 block text-sm font-medium text-ink-700">Attività</span>
            <input
              type="text"
              name="attivita"
              autocomplete="organization"
              class="w-full rounded-xl border border-ink-200 px-4 py-2.5 outline-none transition focus:border-brand-400 focus:ring-2 focus:ring-brand-200"
              placeholder="Es. Panetteria Rossi"
            />
          </label>
        </div>

        <label class="mt-4 block">
          <span class="mb-1.5 block text-sm font-medium text-ink-700">Email *</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            class="w-full rounded-xl border border-ink-200 px-4 py-2.5 outline-none transition focus:border-brand-400 focus:ring-2 focus:ring-brand-200"
            placeholder="tua@email.it"
          />
        </label>

        <label class="mt-4 block">
          <span class="mb-1.5 block text-sm font-medium text-ink-700">Messaggio *</span>
          <textarea
            name="message"
            required
            rows="4"
            class="w-full resize-y rounded-xl border border-ink-200 px-4 py-2.5 outline-none transition focus:border-brand-400 focus:ring-2 focus:ring-brand-200"
            placeholder="Raccontaci cosa ti serve…"
          ></textarea>
        </label>

        <label class="mt-4 flex items-start gap-2.5 text-sm text-ink-500">
          <input type="checkbox" name="privacy_consent" value="accettata" required class="mt-1 h-4 w-4 rounded border-ink-300 text-brand-500" />
          <span>Ho letto la <a href="/privacy" class="font-medium text-brand-600 underline-offset-2 hover:underline">privacy policy</a> e acconsento al trattamento dei dati.</span>
        </label>

        <div class="mt-6">
          <Button type="submit" size="lg" class="w-full">
            Invia richiesta
            <Icon name="arrow" class="h-4 w-4" />
          </Button>
        </div>

        <p id="form-status" class="mt-4 hidden text-center text-sm" role="status" aria-live="polite"></p>
      </form>
    </div>
  </div>
</Section>

<script>
  const form = document.querySelector<HTMLFormElement>("#contact-form");
  const status = document.querySelector<HTMLParagraphElement>("#form-status");

  function showStatus(message: string, ok: boolean) {
    if (!status) return;
    status.textContent = message;
    status.classList.remove("hidden");
    status.classList.toggle("text-emerald-600", ok);
    status.classList.toggle("text-red-600", !ok);
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (form.dataset.keyConfigured !== "true") {
      showStatus(
        "Form in modalità demo: configura la chiave Web3Forms in src/config/site.ts per ricevere i messaggi.",
        false,
      );
      return;
    }

    const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    submitBtn && (submitBtn.disabled = true);
    showStatus("Invio in corso…", true);

    try {
      const res = await fetch(form.action, {
        method: "POST",
        headers: { Accept: "application/json" },
        body: new FormData(form),
      });
      // Parsing isolato: una risposta non-JSON non deve sembrare un errore di rete.
      const data = await res.json().catch(() => null);
      if (res.ok && data?.success) {
        showStatus("Grazie! Ti ricontatteremo al più presto. ✅", true);
        form.reset();
      } else {
        showStatus("Ops, qualcosa è andato storto. Riprova o scrivici via email/WhatsApp.", false);
      }
    } catch {
      showStatus("Connessione non riuscita. Riprova o scrivici via email/WhatsApp.", false);
    } finally {
      submitBtn && (submitBtn.disabled = false);
    }
  });
</script>
