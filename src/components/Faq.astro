---
import Section from "./ui/Section.astro";
import { faqs } from "../data/faq";
---

<Section
  id="faq"
  eyebrow="Domande frequenti"
  title="Le risposte alle domande più comuni"
>
  <div class="mx-auto max-w-3xl divide-y divide-ink-100">
    {
      faqs.map((faq) => (
        <details class="reveal group py-5">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left">
            <span class="text-lg font-semibold text-ink-900">{faq.question}</span>
            <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-ink-50 text-ink-600 transition-transform group-open:rotate-45">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false">
                <path d="M12 5v14M5 12h14"></path>
              </svg>
            </span>
          </summary>
          <p class="mt-3 pr-12 text-ink-500">{faq.answer}</p>
        </details>
      ))
    }
  </div>
</Section>
