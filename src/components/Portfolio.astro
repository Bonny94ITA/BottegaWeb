---
import Section from "./ui/Section.astro";
import Icon from "./ui/Icon.astro";
import { demos } from "../data/portfolio";
---

<Section
  id="esempi"
  eyebrow="Esempi"
  title="Come potrebbe essere la tua attività online"
  subtitle="Alcuni esempi illustrativi per farti un'idea del risultato. Ogni progetto è poi cucito sulla tua attività."
>
  <div class="grid gap-7 md:grid-cols-3">
    {
      demos.map((demo) => (
        <article class="reveal overflow-hidden rounded-2xl border border-ink-100 bg-white shadow-sm transition-all hover:-translate-y-1 hover:shadow-xl">
          <div class={`relative aspect-[4/3] bg-gradient-to-br ${demo.gradient} p-5`}>
            <div class="flex items-center justify-between">
              <span class="rounded-full bg-white/70 px-3 py-1 text-xs font-semibold text-ink-700">
                {demo.category}
              </span>
              <span class="text-3xl">{demo.emoji}</span>
            </div>
            <div class="absolute inset-x-5 bottom-5">
              <div class="rounded-xl bg-white/85 p-3 backdrop-blur">
                <p class="font-display font-bold text-ink-950">{demo.name}</p>
                <div class="mt-2 flex gap-1.5">
                  <span class="h-1.5 w-10 rounded-full bg-ink-900/80" />
                  <span class="h-1.5 w-6 rounded-full bg-ink-300" />
                  <span class="h-1.5 w-4 rounded-full bg-ink-300" />
                </div>
              </div>
            </div>
          </div>
          <div class="p-6">
            <p class="text-ink-600">{demo.blurb}</p>
            <ul class="mt-4 space-y-2">
              {demo.features.map((f) => (
                <li class="flex items-center gap-2 text-sm text-ink-700">
                  <Icon name="check" class="h-4 w-4 text-brand-500" />
                  {f}
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))
    }
  </div>

  <p class="reveal mt-10 text-center text-ink-500">
    Hai un'attività diversa? <a href="/#contatti" class="font-semibold text-brand-600 underline-offset-4 hover:underline">Raccontacela</a> e troviamo la soluzione giusta.
  </p>
</Section>
