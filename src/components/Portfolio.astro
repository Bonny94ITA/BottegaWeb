---
import Section from "./ui/Section.astro";
import Icon from "./ui/Icon.astro";
import { demos } from "../data/portfolio";
---

<Section
  id="esempi"
  eyebrow="Esempi"
  title="Come potrebbe essere la tua attività online"
  subtitle="Alcuni esempi illustrativi per farti un'idea del risultato. Ogni progetto è poi cucito sulla tua attività."
>
  <div class="grid gap-7 md:grid-cols-3">
    {
      demos.map((demo) => (
        <article class="reveal overflow-hidden rounded-2xl border border-ink-100 bg-white shadow-sm transition-all hover:-translate-y-1 hover:shadow-xl">
          <div class={`relative aspect-[4/3] bg-gradient-to-br ${demo.gradient} p-4`}>
            <div class="flex items-center justify-between">
              <span class="rounded-full bg-white/80 px-3 py-1 text-xs font-semibold text-ink-700">
                {demo.category}
              </span>
              <span class="text-2xl drop-shadow-sm">{demo.emoji}</span>
            </div>

            {/* Anteprima stilizzata del sito */}
            <div class="mt-3 rounded-xl bg-white/95 p-3 shadow-lg ring-1 ring-black/5">
              <div class="flex items-center gap-1">
                <span class="h-1.5 w-1.5 rounded-full bg-red-300" />
                <span class="h-1.5 w-1.5 rounded-full bg-amber-300" />
                <span class="h-1.5 w-1.5 rounded-full bg-emerald-300" />
                <span class="ml-1 h-2 flex-1 rounded bg-ink-100" />
              </div>
              <p class="mt-2 font-display text-sm font-bold text-ink-950">{demo.name}</p>
              <div class="mt-1.5 space-y-1">
                <span class="block h-1.5 w-full rounded-full bg-ink-200" />
                <span class="block h-1.5 w-4/5 rounded-full bg-ink-200" />
              </div>
              <div class="mt-2 flex items-center gap-1.5">
                <span class="rounded-md bg-ink-950 px-2 py-1 text-[9px] font-semibold text-white">Ordina</span>
                <span class="rounded-md bg-ink-100 px-2 py-1 text-[9px] font-medium text-ink-600">Menù</span>
              </div>
              <div class="mt-2 grid grid-cols-3 gap-1">
                <span class="aspect-square rounded bg-ink-100" />
                <span class="aspect-square rounded bg-ink-100" />
                <span class="aspect-square rounded bg-ink-100" />
              </div>
            </div>
          </div>
          <div class="p-6">
            <p class="text-ink-600">{demo.blurb}</p>
            <ul class="mt-4 space-y-2">
              {demo.features.map((f) => (
                <li class="flex items-center gap-2 text-sm text-ink-700">
                  <Icon name="check" class="h-4 w-4 text-brand-500" />
                  {f}
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))
    }
  </div>

  <p class="reveal mt-10 text-center text-ink-500">
    Hai un'attività diversa? <a href="/#contatti" class="font-semibold text-brand-600 underline-offset-4 hover:underline">Raccontacela</a> e troviamo la soluzione giusta.
  </p>
</Section>
