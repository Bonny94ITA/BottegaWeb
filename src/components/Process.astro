---
import Section from "./ui/Section.astro";
import { steps } from "../data/process";
---

<Section
  id="metodo"
  tone="dark"
  eyebrow="Come lavoriamo"
  title="Semplice, chiaro, dall'inizio alla fine"
  subtitle="Niente gergo tecnico: ti accompagniamo passo dopo passo."
>
  <ol class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
    {
      steps.map((s, i) => (
        <li class="reveal relative rounded-2xl border border-white/10 bg-white/5 p-7">
          <span class="font-display text-4xl font-extrabold text-brand-400">{s.step}</span>
          <h3 class="mt-3 text-lg font-bold text-white">{s.title}</h3>
          <p class="mt-2 text-ink-300">{s.description}</p>
          {i < steps.length - 1 && (
            <span class="absolute right-6 top-8 hidden text-ink-600 lg:block" aria-hidden="true">
              →
            </span>
          )}
        </li>
      ))
    }
  </ol>
</Section>
