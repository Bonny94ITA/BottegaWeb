---
/**
 * Contenitore di sezione con intestazione opzionale (eyebrow + titolo + sottotitolo).
 * Centralizza spaziatura e larghezza massima per coerenza fra tutte le sezioni.
 */
interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  /** Sfondo alternato per ritmo visivo. */
  tone?: "white" | "muted" | "dark";
  class?: string;
}

const {
  id,
  eyebrow,
  title,
  subtitle,
  tone = "white",
  class: className = "",
} = Astro.props;

const tones = {
  white: "bg-white text-ink-800",
  muted: "bg-ink-50 text-ink-800",
  dark: "bg-ink-950 text-ink-100",
};

const titleColor = tone === "dark" ? "text-white" : "text-ink-950";
const subColor = tone === "dark" ? "text-ink-300" : "text-ink-500";
---

<section id={id} class={`scroll-mt-20 ${tones[tone]} ${className}`}>
  <div class="mx-auto max-w-6xl px-5 py-20 sm:py-24">
    {
      (eyebrow || title || subtitle) && (
        <div class="reveal mx-auto mb-12 max-w-2xl text-center">
          {eyebrow && (
            <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-brand-600">
              {eyebrow}
            </p>
          )}
          {title && (
            <h2 class={`text-3xl font-extrabold sm:text-4xl ${titleColor}`}>
              {title}
            </h2>
          )}
          {subtitle && <p class={`mt-4 text-lg ${subColor}`}>{subtitle}</p>}
        </div>
      )
    }
    <slot />
  </div>
</section>
