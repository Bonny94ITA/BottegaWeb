---
import Button from "./ui/Button.astro";
import Icon from "./ui/Icon.astro";
import { whatsappUrl } from "../config/site";
---

<section id="top" class="relative overflow-hidden bg-ink-950 text-white">
  <!-- Sfondo decorativo -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute -top-32 left-1/4 h-96 w-96 rounded-full bg-brand-500/20 blur-3xl"></div>
    <div class="absolute top-20 right-0 h-80 w-80 rounded-full bg-ink-500/30 blur-3xl"></div>
    <div
      class="absolute inset-0 opacity-[0.07]"
      style="background-image:radial-gradient(circle at 1px 1px, white 1px, transparent 0);background-size:32px 32px;"
    >
    </div>
  </div>

  <div class="relative mx-auto grid max-w-6xl items-center gap-12 px-5 pb-20 pt-36 sm:pt-40 lg:grid-cols-2 lg:pb-28">
    <div>
      <p class="mb-5 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-sm text-ink-100">
        <span class="h-2 w-2 rounded-full bg-brand-400"></span>
        Per panetterie, bar, ristoranti e negozi di quartiere
      </p>

      <h1 class="text-4xl font-extrabold leading-[1.1] sm:text-5xl lg:text-6xl">
        Porta la tua attività
        <span class="bg-gradient-to-r from-brand-300 to-brand-500 bg-clip-text text-transparent">
          online
        </span>, senza complicazioni.
      </h1>

      <p class="mt-6 max-w-xl text-lg text-ink-200">
        Siti web moderni e veloci, menù digitali, prenotazioni e visibilità su
        Google. Tu pensi ai tuoi clienti, al resto pensiamo noi.
      </p>

      <div class="mt-9 flex flex-wrap gap-3">
        <Button href="/#contatti" size="lg">
          Richiedi un preventivo
          <Icon name="arrow" class="h-4 w-4" />
        </Button>
        <Button href="/#esempi" size="lg" variant="ghost" class="!text-white !ring-white/20 hover:!bg-white/10">
          Vedi gli esempi
        </Button>
      </div>

      <div class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-3 text-sm text-ink-300">
        <span class="inline-flex items-center gap-2"><Icon name="check" class="h-4 w-4 text-brand-400" /> Nessun costo nascosto</span>
        <span class="inline-flex items-center gap-2"><Icon name="check" class="h-4 w-4 text-brand-400" /> Pronto in 1–2 settimane</span>
        <span class="inline-flex items-center gap-2"><Icon name="check" class="h-4 w-4 text-brand-400" /> Assistenza inclusa</span>
      </div>
    </div>

    <!-- Mockup browser stilizzato -->
    <div class="reveal relative mx-auto w-full max-w-md lg:max-w-none">
      <div class="rotate-1 rounded-2xl border border-white/10 bg-white/5 p-3 shadow-2xl backdrop-blur">
        <div class="flex items-center gap-1.5 px-2 pb-3 pt-1">
          <span class="h-3 w-3 rounded-full bg-red-400/80"></span>
          <span class="h-3 w-3 rounded-full bg-amber-400/80"></span>
          <span class="h-3 w-3 rounded-full bg-emerald-400/80"></span>
          <span class="ml-3 truncate rounded bg-white/10 px-3 py-1 text-xs text-ink-300">fornoaurora.it</span>
        </div>
        <div class="overflow-hidden rounded-xl bg-gradient-to-br from-amber-50 to-orange-100 p-5 text-ink-900">
          <div class="flex items-center justify-between">
            <span class="text-2xl">🥖</span>
            <span class="rounded-full bg-ink-950 px-3 py-1 text-xs font-semibold text-white">Ordina</span>
          </div>
          <p class="mt-4 font-display text-2xl font-extrabold">Forno Aurora</p>
          <p class="text-sm text-ink-600">Pane, focacce e dolci freschi ogni mattina.</p>
          <div class="mt-4 grid grid-cols-3 gap-2">
            <div class="rounded-lg bg-white/70 p-2 text-center text-xs font-medium">Menù</div>
            <div class="rounded-lg bg-white/70 p-2 text-center text-xs font-medium">Orari</div>
            <div class="rounded-lg bg-white/70 p-2 text-center text-xs font-medium">Mappa</div>
          </div>
        </div>
      </div>

      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener"
        class="absolute -bottom-5 -left-4 flex items-center gap-2 rounded-2xl bg-white px-4 py-3 text-sm font-semibold text-ink-900 shadow-xl ring-1 ring-ink-100 transition-transform hover:-translate-y-0.5"
      >
        <span class="grid h-9 w-9 place-items-center rounded-full bg-emerald-500 text-white">
          <Icon name="whatsapp" class="h-5 w-5" />
        </span>
        Scrivici su WhatsApp
      </a>
    </div>
  </div>
</section>
