---
import Section from "./ui/Section.astro";
import Icon from "./ui/Icon.astro";
import Button from "./ui/Button.astro";
import { plans, maintenanceNote } from "../data/pricing";
---

<Section
  id="prezzi"
  tone="muted"
  eyebrow="Prezzi trasparenti"
  title="Pacchetti chiari, su misura per te"
  subtitle="Prezzi indicativi di partenza. Ogni preventivo è personalizzato in base alle tue esigenze."
>
  <div class="grid items-start gap-7 lg:grid-cols-3">
    {
      plans.map((plan) => (
        <article
          class={`reveal relative flex h-full flex-col rounded-3xl border p-8 transition-all ${
            plan.featured
              ? "border-brand-400 bg-ink-950 text-white shadow-2xl lg:-translate-y-3"
              : "border-ink-100 bg-white text-ink-800 hover:-translate-y-1 hover:shadow-xl"
          }`}
        >
          {plan.featured && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-brand-500 px-4 py-1 text-xs font-bold uppercase tracking-wide text-ink-950">
              Più scelto
            </span>
          )}
          <h3 class={`text-xl font-bold ${plan.featured ? "text-white" : "text-ink-950"}`}>
            {plan.name}
          </h3>
          <p class={`mt-1 text-sm ${plan.featured ? "text-ink-300" : "text-ink-500"}`}>
            {plan.description}
          </p>
          <div class="mt-5 flex items-baseline gap-2">
            <span class="font-display text-4xl font-extrabold">{plan.price}</span>
            <span class="text-ink-400">{plan.period}</span>
          </div>

          <ul class="mt-6 space-y-3 text-sm">
            {plan.features.map((f) => (
              <li class="flex items-start gap-2.5">
                <Icon
                  name="check"
                  class={`mt-0.5 h-4 w-4 shrink-0 ${plan.featured ? "text-brand-400" : "text-brand-500"}`}
                />
                <span class={plan.featured ? "text-ink-100" : "text-ink-700"}>{f}</span>
              </li>
            ))}
          </ul>

          <div class="mt-8 pt-2">
            <Button
              href="/#contatti"
              variant={plan.featured ? "primary" : "ghost"}
              class="w-full"
            >
              {plan.cta}
            </Button>
          </div>
        </article>
      ))
    }
  </div>

  <p class="reveal mx-auto mt-10 max-w-2xl text-center text-ink-500">
    {maintenanceNote}
  </p>
</Section>
