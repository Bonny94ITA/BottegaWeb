---
import Icon from "./ui/Icon.astro";
import { site } from "../config/site";

const year = new Date().getFullYear();

const socials = [
  { name: "instagram", href: site.social.instagram },
  { name: "facebook", href: site.social.facebook },
  { name: "linkedin", href: site.social.linkedin },
].filter((s) => s.href && s.href !== "#");
---

<footer class="bg-ink-950 text-ink-300">
  <div class="mx-auto max-w-6xl px-5 py-14">
    <div class="grid gap-10 md:grid-cols-3">
      <div>
        <a href="/#top" class="flex items-center gap-2 font-display text-lg font-extrabold text-white">
          <span class="grid h-8 w-8 place-items-center rounded-lg bg-brand-500 text-ink-950">B</span>
          {site.name}
        </a>
        <p class="mt-3 max-w-xs text-sm text-ink-400">{site.tagline}.</p>
        {
          socials.length > 0 && (
            <div class="mt-5 flex gap-3">
              {socials.map((s) => (
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener"
                  aria-label={s.name}
                  class="grid h-9 w-9 place-items-center rounded-full border border-white/10 text-ink-300 transition-colors hover:bg-white/10 hover:text-white"
                >
                  <Icon name={s.name} class="h-4 w-4" />
                </a>
              ))}
            </div>
          )
        }
      </div>

      <div>
        <p class="text-sm font-semibold uppercase tracking-wider text-ink-500">Naviga</p>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href="/#servizi" class="hover:text-white">Servizi</a></li>
          <li><a href="/#esempi" class="hover:text-white">Esempi</a></li>
          <li><a href="/#prezzi" class="hover:text-white">Prezzi</a></li>
          <li><a href="/#faq" class="hover:text-white">FAQ</a></li>
          <li><a href="/privacy" class="hover:text-white">Privacy</a></li>
        </ul>
      </div>

      <div>
        <p class="text-sm font-semibold uppercase tracking-wider text-ink-500">Contatti</p>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href={`mailto:${site.email}`} class="hover:text-white">{site.email}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-3 border-t border-white/10 pt-6 text-xs text-ink-500 sm:flex-row">
      <p>© {year} {site.name}. Tutti i diritti riservati. · P.IVA 00000000000</p>
      <p>Realizzato con cura per le attività locali.</p>
    </div>
  </div>
</footer>
