---
import Section from "./ui/Section.astro";
import Icon from "./ui/Icon.astro";
import { services } from "../data/services";
---

<Section
  id="servizi"
  tone="muted"
  eyebrow="Cosa facciamo"
  title="Tutto quello che serve per farti trovare e scegliere"
  subtitle="Servizi pensati per le piccole attività locali: concreti, su misura e senza tecnicismi."
>
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      services.map((service) => (
        <article class="reveal group rounded-2xl border border-ink-100 bg-white p-7 shadow-sm transition-all hover:-translate-y-1 hover:border-brand-200 hover:shadow-xl">
          <div class="mb-5 grid h-12 w-12 place-items-center rounded-xl bg-brand-50 text-brand-600 transition-colors group-hover:bg-brand-500 group-hover:text-ink-950">
            <Icon name={service.icon} class="h-6 w-6" />
          </div>
          <h3 class="text-lg font-bold">{service.title}</h3>
          <p class="mt-2 text-ink-500">{service.description}</p>
        </article>
      ))
    }
  </div>
</Section>
