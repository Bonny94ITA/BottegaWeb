---
import Base from "../layouts/Base.astro";
import Button from "../components/ui/Button.astro";
---

<Base title="Pagina non trovata">
  <section class="grid min-h-[70vh] place-items-center bg-ink-950 px-5 text-center text-white">
    <div>
      <p class="font-display text-7xl font-extrabold text-brand-500">404</p>
      <h1 class="mt-4 text-2xl font-bold">Questa pagina non esiste</h1>
      <p class="mt-2 text-ink-300">Forse il link è cambiato o c'è un errore di battitura.</p>
      <div class="mt-8">
        <Button href="/" size="lg">Torna alla home</Button>
      </div>
    </div>
  </section>
</Base>
